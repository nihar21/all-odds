# Copy to `server/.env` and fill in. Loaded via `node --env-file` (see scripts).

# the-odds-api.com key. Falls back to the project's bundled public key if unset,
# but production should use a private key so it never reaches the client.
ODDS_API_KEY=

# Optional overrides
# PORT=4000
# ODDS_API_BASE_URL=https://api.the-odds-api.com/v4
# CACHE_TTL_LEAGUES=3600000
# CACHE_TTL_EVENTS=60000
# CACHE_TTL_SCORES=25000
