# Copy to .env to override the bundled odds-API key.
# Get a key at https://the-odds-api.com/
VITE_ODDS_API_KEY=

# Optional: point the app at the GraphQL backend in server/ (see server/README.md).
# When unset, the app calls the-odds-api directly (the client-only default).
# VITE_GRAPHQL_URL=http://localhost:4000/
